# Ollama
LUME_OLLAMA_BASE_URL=http://127.0.0.1:11434
LUME_MODEL=gemma4:12b-mlx

# Bind
LUME_BIND_HOST=0.0.0.0
LUME_BIND_PORT=8000

# First-launch only: seed an admin key into the DB. After the first boot,
# you can unset this and manage keys via the admin API.
LUME_ADMIN_BOOTSTRAP_KEY=change-me-to-a-long-random-string

# Voice
LUME_WHISPER_BIN=~/.local/bin/whisper
LUME_WHISPER_MODEL=turbo
LUME_WHISPER_DEVICE=cpu
LUME_SUPERTONIC_ENABLED=true
LUME_SUPERTONIC_VOICE=M1
LUME_SUPERTONIC_STEPS=8
LUME_SUPERTONIC_SPEED=1.0
LUME_SUPERTONIC_LANG=na

# Tool loop
LUME_MAX_TOOL_ITERATIONS=6